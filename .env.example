# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# === Anthropic ===
# From https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxx

# === Slack ===
# From your Slack app at https://api.slack.com/apps
# Bot User OAuth Token (xoxb-...) — from "Install App" page
SLACK_BOT_TOKEN=xoxb-xxx

# Signing Secret — from "Basic Information" page
SLACK_SIGNING_SECRET=xxx

# App-Level Token (xapp-...) for Socket Mode — from "Basic Information" → "App-Level Tokens"
# Must have scope `connections:write`
SLACK_APP_TOKEN=xapp-xxx

# Channel ID of #workspace-lab (right-click channel → Copy link, ID is the last segment)
WORKSPACE_LAB_CHANNEL_ID=C0XXXXXXXXX

# === Google ===
# Local paths on the machine running the bot (Mac for first OAuth, Hetzner for prod)
GOOGLE_OAUTH_CLIENT_PATH=/home/youruser/.config/outrizz/google_oauth_client.json
GOOGLE_TOKEN_PATH=/home/youruser/.config/outrizz/google_token.json

# ID of the "Outrizz / Lab/" folder on Google Drive
# Get it from the URL: https://drive.google.com/drive/folders/<ID>
DRIVE_LAB_FOLDER_ID=

# === Runtime ===
# Path to state.json (run registry)
STATE_PATH=./state.json

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
